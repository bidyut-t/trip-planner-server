PORT=8081
USE_OPENAI_SDK=true
# Required when USE_OPENAI_SDK=true or for /api/trips/plan/natural
OPENAI_API_KEY=
# OpenAI model for AI steps (default: gpt-4o-mini)
OPENAI_MODEL=gemini-2.5-flash-lite
# Max km from current stop to swap in catalog restaurant/activity/game (default: 4)
NEARBY_CATALOG_RADIUS_KM=4
# Attach trip-catalog MCP server to AI prompts (default: on when USE_OPENAI_SDK=true)
USE_CATALOG_MCP=true
# Use AI to generate destination data for unknown cities (default: on when USE_OPENAI_SDK=true)
USE_AI_ENHANCED_DESTINATIONS=true
# Frontend base URL for CORS
FRONTEND_BASE_URL=http://localhost:3002
