PORT=8081
USE_CURSOR_SDK=true
# Required when USE_CURSOR_SDK=true or for /api/trips/plan/natural
CURSOR_API_KEY=
# Fast model for AI steps (default: gemini-3-flash)
CURSOR_MODEL=gemini-3-flash
# Max km from current stop to swap in catalog restaurant/activity/game (default: 4)
NEARBY_CATALOG_RADIUS_KM=4
